# Fully rewritten for Linux target

{
  "CompileFlags": {
    "Add": [
      "-funsigned-char",
      "-DLINUX",
      "-DFNFLOAT",
      "-DCK_POSIX_SIG",
      "-DCK_NEWTERM",
      "-DTCPSOCKET",
      "-DLINUXFSSTND",
      "-DNOCOTFMC",
      "-DPOSIX",
      "-DUSE_STRERROR",
    ]
  },
  "Index": {
    "Background": "Build"
  },
  "Completion": {
    "AllScopes": true
  }
}
